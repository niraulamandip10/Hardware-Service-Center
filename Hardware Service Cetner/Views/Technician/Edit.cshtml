@model TechnicianModel

@{
    ViewData["Title"] = "Edit Technician";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-warning text-dark rounded-top-4 py-3">
                <h4 class="mb-0"><i class="bi bi-pencil-fill me-2"></i>Edit Technician</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" novalidate>
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Name" class="form-control" placeholder="Full Name" />
                                <label asp-for="Name"></label>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Code" class="form-control" placeholder="Technician Code" />
                                <label asp-for="Code"></label>
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating mb-3">
                                <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 120px"></textarea>
                                <label asp-for="Description"></label>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Report" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-warning btn-lg px-5">
                            <i class="bi bi-check-lg me-1"></i> Update Technician
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
