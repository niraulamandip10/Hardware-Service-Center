@model IEnumerable<DeviceModel>

@{
    ViewData["Title"] = "Devices";
    var totalDevices = Model.Count();
    var activeDevices = Model.Count(d => d.Status);
    var inactiveDevices = totalDevices - activeDevices;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-start border-success border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <span class="fw-medium">@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                <li class="breadcrumb-item active fw-semibold" aria-current="page">Devices</li>
            </ol>
        </nav>
        <h2 class="mb-0 fw-bold text-dark"><i class="bi bi-display fs-3 me-2 text-primary"></i>All Devices</h2>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm rounded-3 px-4">
        <i class="bi bi-plus-circle-fill fs-5 me-2 align-middle"></i>Add New Device
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-primary bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-device-hdd fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Total Devices</p>
                    <h3 class="mb-0 fw-bold fs-1">@totalDevices</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-success bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-toggle-on fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Active Devices</p>
                    <h3 class="mb-0 fw-bold fs-1">@activeDevices</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-secondary bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-toggle-off fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Inactive Devices</p>
                    <h3 class="mb-0 fw-bold fs-1">@inactiveDevices</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white rounded-top-4 py-3 px-4 border-bottom">
        <div class="row align-items-center g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 rounded-start-3">
                        <i class="bi bi-search fs-5 text-muted"></i>
                    </span>
                    <input type="text" id="deviceSearch" class="form-control border-start-0 ps-0 rounded-end-3" placeholder="Search by name or description..." />
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                <span class="text-muted small fw-medium">
                    <i class="bi bi-layout-text-window me-1"></i>Showing <strong>@totalDevices</strong> device(s)
                </span>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="deviceTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 fw-semibold text-muted" style="width: 60px;">S.N</th>
                        <th class="py-3 fw-semibold text-muted">
                            <i class="bi bi-tag-fill me-2 text-primary"></i>@Html.DisplayNameFor(m => m.Name)
                        </th>
                        <th class="py-3 fw-semibold text-muted">
                            <i class="bi bi-card-text me-2 text-primary"></i>@Html.DisplayNameFor(m => m.Description)
                        </th>
                        <th class="text-center py-3 fw-semibold text-muted" style="width: 140px;">
                            <i class="bi bi-toggle-on me-2 text-primary"></i>@Html.DisplayNameFor(m => m.Status)
                        </th>
                        <th class="text-center py-3 pe-4 fw-semibold text-muted" style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var device in Model)
                        {
                            <tr class="device-row">
                                <td class="fw-semibold ps-4 text-muted py-3">@(i++)</td>
                                <td class="fw-semibold py-3">
                                    <span class="d-inline-block bg-primary bg-opacity-10 text-primary rounded-2 px-3 py-1">
                                        <i class="bi bi-display me-1"></i>@device.Name
                                    </span>
                                </td>
                                <td class="text-muted py-3">@(device.Description ?? "-")</td>
                                <td class="text-center py-3">
                                    @if (device.Status)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-semibold">
                                            <i class="bi bi-check-circle-fill me-1"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2 fw-semibold">
                                            <i class="bi bi-x-circle-fill me-1"></i>Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-center py-3 pe-4">
                                    <a asp-action="Edit" asp-route-id="@device.Id"
                                       class="btn btn-sm btn-outline-warning rounded-3 me-1 px-3"
                                       title="Edit Device">
                                        <i class="bi bi-pencil-fill fs-6"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" asp-route-id="@device.Id" class="d-inline">
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger rounded-3 px-3"
                                                onclick="return confirm('Delete this device permanently?')"
                                                title="Delete Device">
                                            <i class="bi bi-trash-fill fs-6"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-display text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">No Devices Found</h5>
                                    <p class="text-muted mb-0">Get started by adding your first device.</p>
                                    <a asp-action="Create" class="btn btn-primary mt-3 rounded-3 px-4">
                                        <i class="bi bi-plus-circle-fill me-2"></i>Add New Device
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

