@model IEnumerable<DeviceModel>

@{
    ViewData["Title"] = "Devices";
    var totalDevices = Model.Count();
    var activeDevices = Model.Count(d => d.Status);
    var inactiveDevices = totalDevices - activeDevices;
}

<div class="page-content">
    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="theme-alert alert-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span class="fw-medium">@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Devices</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-display me-2 text-primary"></i>All Devices</h2>
        </div>
        <div class="header-actions">
            <a asp-action="Create" class="btn-primary-blue">
                <i class="bi bi-plus-circle-fill"></i>Add New Device
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(13,110,253,0.12); color: #0d6efd;">
                        <i class="bi bi-device-hdd"></i>
                    </div>
                    <div>
                        <p class="stat-label">Total Devices</p>
                        <p class="stat-value">@totalDevices</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(25,135,84,0.12); color: #198754;">
                        <i class="bi bi-toggle-on"></i>
                    </div>
                    <div>
                        <p class="stat-label">Active Devices</p>
                        <p class="stat-value">@activeDevices</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(108,117,125,0.12); color: #6c757d;">
                        <i class="bi bi-toggle-off"></i>
                    </div>
                    <div>
                        <p class="stat-label">Inactive Devices</p>
                        <p class="stat-value">@inactiveDevices</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="theme-table-wrapper">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" id="deviceSearch" placeholder="Search by name or description..." />
            </div>
            <span class="text-muted small fw-medium">
                <i class="bi bi-layout-text-window me-1"></i>Showing <strong>@totalDevices</strong> device(s)
            </span>
        </div>
        <div class="table-responsive">
            <table class="table-custom" id="deviceTable">
                <thead>
                    <tr>
                        <th>S.N</th>
                        <th>@Html.DisplayNameFor(m => m.Name)</th>
                        <th>@Html.DisplayNameFor(m => m.Description)</th>
                        <th class="text-center">@Html.DisplayNameFor(m => m.Status)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var device in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-muted">@(i++)</td>
                                <td class="fw-semibold">
                                    <span class="d-inline-block bg-primary bg-opacity-10 text-primary rounded-2 px-3 py-1">
                                        <i class="bi bi-display me-1"></i>@device.Name
                                    </span>
                                </td>
                                <td class="text-muted">@(device.Description ?? "-")</td>
                                <td class="text-center">
                                    @if (device.Status)
                                    {
                                        <span class="badge-custom badge-completed"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-pending"><i class="bi bi-x-circle-fill me-1"></i>Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@device.Id" class="btn-secondary-outline btn-sm" title="Edit Device">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" asp-route-id="@device.Id" class="d-inline">
                                        <button type="submit" class="btn-secondary-outline btn-sm"
                                                onclick="return confirm('Delete this device permanently?')" title="Delete Device">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-display text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">No Devices Found</h5>
                                    <p class="text-muted mb-0">Get started by adding your first device.</p>
                                    <a asp-action="Create" class="btn-primary-blue mt-3">
                                        <i class="bi bi-plus-circle-fill me-2"></i>Add New Device
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deviceSearch')?.addEventListener('keyup', function () {
            const value = this.value.toLowerCase();
            document.querySelectorAll('#deviceTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? '' : 'none';
            });
        });
    </script>
}
