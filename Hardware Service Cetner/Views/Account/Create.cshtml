@model AccountModel

@{
    ViewData["Title"] = "Create Users";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-primary text-white rounded-top-4 py-3">
                <h4 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Register New Account</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Name" class="form-control" placeholder="Full Name" />
                                <label asp-for="Name"></label>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Email" class="form-control" placeholder="Email Address" />
                                <label asp-for="Email"></label>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Phone" class="form-control" placeholder="Phone Number" />
                                <label asp-for="Phone"></label>
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Address" class="form-control" placeholder="Address" />
                                <label asp-for="Address"></label>
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Username" class="form-control" placeholder="Username" />
                                <label asp-for="Username"></label>
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Password" class="form-control" placeholder="Password" />
                                <label asp-for="Password"></label>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Report" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="bi bi-arrow-left me-1"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            <i class="bi bi-check-lg me-1"></i> Save Account
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


