@model DeviceModel

@{
    ViewData["Title"] = "Edit Device";
}

<div class="page-content">

    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Report"><i class="bi bi-display me-1"></i>Devices</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Edit</li>
                </ol>
            </nav>
            <h3 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-warning"></i>Edit Device</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="theme-card">
                <div class="theme-card-header">
                    <div class="header-icon bg-warning text-dark">
                        <i class="bi bi-pencil-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Device Information</h5>
                        <small>Update the device details below</small>
                    </div>
                </div>
                <div class="theme-card-body">
                    <form asp-action="Edit" method="post" novalidate>
                        <input type="hidden" asp-for="Id" />
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Name" class="form-control" placeholder="Device Name" />
                                    <label asp-for="Name"><i class="bi bi-tag-fill me-2 text-primary"></i>Device Name</label>
                                    <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 120px"></textarea>
                                    <label asp-for="Description"><i class="bi bi-card-text me-2 text-primary"></i>Description</label>
                                    <span asp-validation-for="Description" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card bg-light border-0 rounded-3 p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-3 bg-white shadow-sm p-2 me-3">
                                            <i class="bi bi-toggle-on fs-4 text-primary"></i>
                                        </div>
                                        <div class="form-check form-switch mb-0">
                                            <input asp-for="Status" class="form-check-input" role="switch" style="width: 3em; height: 1.5em;" />
                                            <label asp-for="Status" class="form-check-label fw-semibold ms-2"></label>
                                            <div class="text-muted small mt-1">
                                                <i class="bi bi-info-circle me-1"></i>Toggle to mark device as active or inactive
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Report" class="btn-secondary-outline px-4">
                                <i class="bi bi-arrow-left"></i>Cancel
                            </a>
                            <button type="submit" class="btn-warning px-5">
                                <i class="bi bi-check-lg"></i>Update
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
