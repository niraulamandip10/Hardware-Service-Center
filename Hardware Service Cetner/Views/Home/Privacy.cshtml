@model ErrorViewModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="privacy-container" style="max-width: 800px; margin: 0 auto; font-family: sans-serif; color: #333; line-height: 1.6;">
    
    <h1 style="border-bottom: 2px solid #0066cc; padding-bottom: 10px; color: #111;">@ViewData["Title"]</h1>
    
    <p style="color: #666; font-size: 0.9rem; margin-bottom: 30px;">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

    <p>At our PC Service Center, we take your privacy and data security seriously. This policy outlines how we handle your personal and device data when you trust us with your hardware repairs.</p>

    <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;" />

    <section style="margin-bottom: 25px;">
        <h2 style="color: #0066cc; font-size: 1.3rem; margin-bottom: 10px;">1. Information We Collect</h2>
        <p>To provide repair and maintenance services, we collect:</p>
        <ul style="padding-left: 20px;">
            <li><strong style="color: #0066cc;">Contact Information:</strong> Your name, phone number, and email address.</li>
            <li><strong style="color: #0066cc;">Device Information:</strong> PC hardware specifications, serial numbers, passwords (if required for testing), and operating system details.</li>
        </ul>
    </section>

    <section style="margin-bottom: 25px;">
        <h2 style="color: #0066cc; font-size: 1.3rem; margin-bottom: 10px;">2. How We Use Your Data</h2>
        <p>Your data is used strictly for fulfilling your service requests:</p>
        <ul style="padding-left: 20px;">
            <li>Diagnosing and repairing hardware and software faults.</li>
            <li>Contacting you with status updates and quotes.</li>
            <li>Verifying warranty claims and part compatibility.</li>
        </ul>
    </section>

    <section style="margin-bottom: 25px;">
        <h2 style="color: #0066cc; font-size: 1.3rem; margin-bottom: 10px;">3. Data Security & Storage</h2>
        <p>We implement strict boundaries regarding your personal files:</p>
        <ul style="padding-left: 20px;">
            <li><strong style="color: #0066cc;">No Data Browsing:</strong> Technicians will only access directories necessary to resolve your specific technical issue.</li>
            <li><strong style="color: #0066cc;">Temporary Backups:</strong> If a data backup is required during a drive replacement, your data is securely stored on our local drives and permanently deleted once the repair is verified and collected.</li>
        </ul>
    </section>

    <section style="margin-bottom: 25px;">
        <h2 style="color: #0066cc; font-size: 1.3rem; margin-bottom: 10px;">4. Third-Party Sharing</h2>
        <p>We do not sell, trade, or lease your personal data. We may only share hardware details with component manufacturers to process official warranty replacements on your behalf.</p>
    </section>

    <section style="margin-bottom: 25px;">
        <h2 style="color: #0066cc; font-size: 1.3rem; margin-bottom: 10px;">5. Contact Us</h2>
        <p>If you have any questions regarding your data safety or wish to request the immediate deletion of your contact records after service completion, please reach out to our service desk staff.</p>
    </section>

</div>