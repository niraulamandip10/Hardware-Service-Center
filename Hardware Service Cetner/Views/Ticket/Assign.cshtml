@model TicketReportViewModel
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Assign Ticket";
    var technicians = ViewBag.Technicians as IEnumerable<TechnicianModel>;
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-info text-white rounded-top-4 py-3 px-4">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 bg-white bg-opacity-25 p-2 me-3">
                        <i class="bi bi-person-plus-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-semibold">Assign Ticket</h5>
                        <span class="small opacity-75">@Model.TicketNo</span>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="card bg-light border-0 rounded-3 p-3">
                            <small class="text-muted">Customer</small>
                            <div class="fw-semibold">@Model.CustomerName</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light border-0 rounded-3 p-3">
                            <small class="text-muted">Device</small>
                            <div class="fw-semibold">@Model.DeviceName</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="card bg-light border-0 rounded-3 p-3">
                            <small class="text-muted">Description</small>
                            <div class="fw-semibold">@Model.TicketDescription</div>
                        </div>
                    </div>
                </div>

                <form asp-action="Assign" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="row g-4">
                        <div class="col-12">
                            <div class="form-floating">
                                <select name="technicianId" class="form-select rounded-3" required>
                                    <option value="">-- Select Technician --</option>
                                    @if (technicians != null)
                                    {
                                        foreach (var tech in technicians)
                                        {
                                            <option value="@tech.Id">@tech.Name</option>
                                        }
                                    }
                                </select>
                                <label><i class="bi bi-person-gear me-2 text-info"></i>Assign Technician</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <select name="ticketStatus" class="form-select rounded-3">
                                    <option value="@((int)TicketStatus.Assigned)">Assigned</option>
                                    <option value="@((int)TicketStatus.Repairing)">Repairing</option>
                                </select>
                                <label><i class="bi bi-arrow-right-circle me-2 text-info"></i>Initial Status</label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Report" class="btn btn-outline-secondary rounded-3 px-4 py-2">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-info text-white rounded-3 px-5 py-2 shadow-sm">
                            <i class="bi bi-check-lg me-1"></i>Assign
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
