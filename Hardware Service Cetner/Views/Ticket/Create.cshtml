@model TicketModel

@{
    ViewData["Title"] = "Create Ticket";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-start border-success border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <span class="fw-medium">@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house-fill me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Report" class="text-decoration-none"><i class="bi bi-ticket-detailed me-1"></i>Tickets</a></li>
            <li class="breadcrumb-item active fw-semibold" aria-current="page">Create</li>
        </ol>
    </nav>
    <h3 class="fw-bold text-dark mb-0"><i class="bi bi-plus-circle-fill fs-3 me-2 text-primary"></i>Register New Ticket</h3>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-primary text-white rounded-top-4 py-3 px-4">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 bg-white bg-opacity-25 p-2 me-3">
                        <i class="bi bi-ticket-detailed-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-semibold">Ticket Information</h5>
                        <span class="small opacity-75">Fill in the details below to create a new service ticket</span>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" novalidate>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="CustomerId" class="form-select rounded-3" asp-items="@(new SelectList(ViewBag.getCustomer, "Id", "Name"))">
                                    <option value="">-- Select Customer --</option>
                                </select>
                                <label asp-for="CustomerId"><i class="bi bi-person-fill me-2 text-primary"></i>Customer</label>
                                <span asp-validation-for="CustomerId" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                       
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="DeviceId" class="form-select rounded-3" asp-items="@(new SelectList(ViewBag.getDevice, "Id", "Name"))">
                                    <option value="">-- Select Device --</option>
                                </select>
                                <label asp-for="DeviceId"><i class="bi bi-display-fill me-2 text-primary"></i>Device</label>
                                <span asp-validation-for="DeviceId" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="RecById" class="form-select rounded-3" asp-items="@(new SelectList(ViewBag.getRecById, "Id", "Name"))">
                                    <option value="">-- Select Received By --</option>
                                </select>
                                <label asp-for="RecById"><i class="bi bi-person-badge-fill me-2 text-primary"></i>Received By</label>
                                <span asp-validation-for="RecById" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea asp-for="TicketDescription" class="form-control rounded-3" placeholder="Ticket Description" style="height: 120px"></textarea>
                                <label asp-for="TicketDescription"><i class="bi bi-card-text me-2 text-primary"></i>Ticket Description</label>
                                <span asp-validation-for="TicketDescription" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light border-0 rounded-3 p-3">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-3 bg-white shadow-sm p-2 me-3">
                                        <i class="bi bi-calendar-date fs-4 text-primary"></i>
                                    </div>
                                    <div>
                                        <span class="text-muted small">Received Date</span>
                                        <div class="fw-semibold">@DateTime.Now.ToString("dd MMM yyyy HH:mm")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Report" class="btn btn-outline-secondary rounded-3 px-4 py-2">
                            <i class="bi bi-arrow-left fs-5 me-1 align-middle"></i>Back to List
                        </a>
                        <button type="submit" class="btn btn-primary rounded-3 px-5 py-2 shadow-sm">
                            <i class="bi bi-check-lg fs-5 me-1 align-middle"></i>Save Ticket
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
