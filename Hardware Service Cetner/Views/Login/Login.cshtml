@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hardware Service Center</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hardware_Service_Cetner.styles.css" asp-append-version="true" />

    <style>
        html,
        body {
            height: 100%;
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #f4f6f9;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            background:
                radial-gradient(circle at top left,#dbeafe 0,#f4f6f9 45%),
                radial-gradient(circle at bottom right,#e2e8f0 0,#f4f6f9 50%);
        }

        .login-modal {
            width: 100%;
            max-width: 420px;
        }

        .login-card {
            border: none;
            border-radius: 18px;
            background: rgba(255,255,255,.95);
            backdrop-filter: blur(12px);
            box-shadow: 0 20px 45px rgba(0,0,0,.08);
            overflow: hidden;
        }

        .login-header {
            text-align: center;
            padding: 2rem 2rem 1rem;
        }

        .login-icon {
            width: 72px;
            height: 72px;
            margin: auto;
            border-radius: 50%;
            background: #0d6efd;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 1rem;
        }

        .login-header h3 {
            font-weight: 600;
            margin-bottom: .35rem;
        }

        .login-header p {
            color: #6c757d;
            margin-bottom: 0;
            font-size: .95rem;
        }

        .login-body {
            padding: 2rem;
        }

        .form-control {
            border-radius: 12px;
            min-height: 58px;
        }

        .form-floating label {
            color: #6c757d;
        }

        .btn-primary {
            border-radius: 12px;
            padding: .9rem;
            font-weight: 600;
        }

        .register-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: .95rem;
        }

        .register-link a {
            text-decoration: none;
            font-weight: 500;
        }

        .alert {
            border-radius: 12px;
        }

        @@media (max-width:576px) {

            .login-header {
                padding: 1.75rem 1.5rem 1rem;
            }

            .login-body {
                padding: 1.5rem;
            }

            .login-icon {
                width: 64px;
                height: 64px;
                font-size: 1.5rem;
            }
        }
    </style>
</head>

<body>

    <div class="login-modal">

        <div class="login-card">

            <div class="login-header">
                <div class="login-icon">
                    <i class="bi bi-tools"></i>
                </div>

                <h3>Hardware Service Center</h3>
                <p>Sign in to continue</p>
            </div>

            <div class="login-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" novalidate>

                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control" placeholder="Username" />
                        <label asp-for="Username"></label>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Password" class="form-control" placeholder="Password" />
                        <label asp-for="Password"></label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        Sign In
                    </button>

                </form>

                @if (ViewBag.CanRegister == true)
                {
                    <div class="register-link">
                        <a asp-controller="Account" asp-action="Create">
                            <i class="bi bi-person-plus me-1"></i>
                            Create first account
                        </a>
                    </div>
                }

            </div>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
