@model IEnumerable<TicketReportViewModel>
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Assigned Tickets";
    var total = Model.Count();
}

<div class="page-content">

    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Report"><i class="bi bi-ticket-detailed me-1"></i>Tickets</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Assigned</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-person-check fs-3 me-2 text-primary"></i>Assigned Tickets</h2>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(6,182,212,0.12); color: #06b6d4;">
                        <i class="bi bi-person-check"></i>
                    </div>
                    <div>
                        <p class="stat-label">Assigned Tickets</p>
                        <p class="stat-value">@total</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="theme-table-wrapper">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" id="assignedSearch" placeholder="Search by ticket no, technician..." />
            </div>
            <span class="text-muted small fw-medium">
                <i class="bi bi-layout-text-window me-1"></i>
                Showing <strong>@total</strong> assigned ticket(s)
            </span>
        </div>
        <div class="table-responsive">
            <table class="table-custom" id="assignedTable">
                <thead>
                    <tr>
                        <th style="width: 60px;">S.N</th>
                        <th>Ticket No</th>
                        <th>Customer</th>
                        <th>Device</th>
                        <th>Technician</th>
                        <th>Description</th>
                        <th class="text-center" style="width: 160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-muted">@(i++)</td>
                                <td class="fw-semibold">
                                    <span class="badge-custom badge-assigned"><i class="bi bi-ticket me-1"></i>@ticket.TicketNo</span>
                                </td>
                                <td><i class="bi bi-person-fill text-muted me-1"></i>@ticket.CustomerName</td>
                                <td><i class="bi bi-display text-muted me-1"></i>@ticket.DeviceName</td>
                                <td>
                                    <span class="badge-custom badge-assigned">
                                        <i class="bi bi-person-gear me-1"></i>@ticket.TechnicianName
                                    </span>
                                </td>
                                <td class="text-muted small" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @(ticket.TicketDescription ?? "-")
                                </td>
                                <td class="text-center">
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@ticket.Id" />
                                        <input type="hidden" name="ticketStatus" value="@((int)TicketStatus.Repairing)" />
                                        <button type="submit" class="btn-primary-blue btn-sm"
                                                title="Start Repairing">
                                            <i class="bi bi-tools me-1"></i>Start Repair
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">No Assigned Tickets</h5>
                                    <p class="text-muted mb-0">Assign tickets to technicians from the Ticket Report.</p>
                                    <a asp-action="Report" class="btn-primary-blue mt-3">
                                        <i class="bi bi-ticket-detailed me-2"></i>Go to Ticket Report
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('assignedSearch')?.addEventListener('keyup', function () {
            const value = this.value.toLowerCase();
            document.querySelectorAll('#assignedTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? '' : 'none';
            });
        });
    </script>
}
