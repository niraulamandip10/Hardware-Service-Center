@using System.Net
@model IEnumerable<CustomerModel>

@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-people-fill me-2"></i>All Customers</h2>
    <a asp-action="Create" class="btn btn-primary btn-lg">
        <i class="bi bi-person-plus-fill me-1"></i> Add New Customer
    </a>
</div>

<div class="card shadow border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr>
                        <th class="ps-4">S.N</th>
                        <th>@Html.DisplayNameFor(m => m.Name)</th>
                        <th>@Html.DisplayNameFor(m => m.Email)</th>
                        <th>@Html.DisplayNameFor(m => m.Phone)</th>
                        <th>@Html.DisplayNameFor(m => m.Address)</th>
                        <th class="text-center">@Html.DisplayNameFor(m => m.Status)</th>
                        <th class="text-center pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var customer in Model)
                        {
                            <tr>
                                <td class="fw-semibold ps-4 text-muted">@(i++)</td>
                                <td class="fw-medium">@customer.Name</td>
                                <td>@(customer.Email ?? "-")</td>
                                <td>@customer.Phone</td>
                                <td>@customer.Address</td>
                                <td class="text-center">
                                    @if (customer.Status == CustomerStatus.Active)
                                    {
                                        <span class="badge bg-success rounded-pill">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">Inactive</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-warning me-1" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    @if (customer.Status == CustomerStatus.Active)
                                    {
                                        <form asp-action="Deactivate" method="post" asp-route-id="@customer.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary me-1" title="Deactivate">
                                                <i class="bi bi-pause-fill"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Activate" method="post" asp-route-id="@customer.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success me-1" title="Activate">
                                                <i class="bi bi-play-fill"></i>
                                            </button>
                                        </form>
                                    }

                                    <form asp-action="Delete" method="post" asp-route-id="@customer.Id" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Are you sure you want to delete this customer?')" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No customers found.
                                <a asp-action="Create" class="d-block mt-2">Create the first customer</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>