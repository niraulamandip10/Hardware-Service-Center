    <div class="row g-3 analytics-row">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white rounded-top-4 py-3 px-4 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2 text-success"></i>Customer Analytics</h5>
                        <p class="mb-0 text-muted small">Customer acquisition and retention</p>
                    </div>
                    <div class="d-flex gap-3 small">
                        <span class="d-flex align-items-center"><span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#0077B6"></span> New</span>
                        <span class="d-flex align-items-center"><span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#f59e0b"></span> Returning</span>
                    </div>
                </div>
                <div class="card-body-scroll">
                    <div class="row g-2 mb-3 text-center">
                        <div class="col-4">
                            <div class="bg-light rounded-3 p-2">
                                <p class="text-muted small fw-medium mb-0">New</p>
                                <h4 class="fw-bold mb-0 text-primary" id="newCustomers">@Model.NewCustomers</h4>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light rounded-3 p-2">
                                <p class="text-muted small fw-medium mb-0">Returning</p>
                                <h4 class="fw-bold mb-0 text-warning" id="returningCustomers">@Model.ReturningCustomers</h4>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light rounded-3 p-2">
                                <p class="text-muted small fw-medium mb-0">Total</p>
                                <h4 class="fw-bold mb-0 text-dark" id="totalCustomersDisplay">@Model.TotalCustomers</h4>
                            </div>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas id="customersChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white rounded-top-4 py-3 px-4 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold"><i class="bi bi-trophy-fill me-2 text-purple" style="color:#8b5cf6"></i>Technician Performance</h5>
                        <p class="mb-0 text-muted small">Ranked by completed work and revenue</p>
                    </div>
                </div>
                <div class="card-body-scroll">
                    <div class="chart-container">
                        <canvas id="technicianChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    

</div>

<script id="initialData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))</script>

@section Scripts {
    <script>
        (function () {
            'use strict';
            var COLORS = {
                primary: '#0077B6',
                primaryLight: 'rgba(0,119,182,0.15)',
                success: '#10b981',
                successLight: 'rgba(16,185,129,0.15)',
                warning: '#f59e0b',
                warningLight: 'rgba(245,158,11,0.15)',
                danger: '#ef4444',
                info: '#06b6d4',
                purple: '#8b5cf6',
                purpleLight: 'rgba(139,92,246,0.15)',
            };

            var formatter = {
                format: function (value) {
                    return 'Rs ' + Number(value).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                }
            };

            var charts = {};
            var resizeRafs = {};

            /* ---------- Safe canvas access ---------- */
            function getCanvas(id) {
                var el = document.getElementById(id);
                if (!el || !(el instanceof HTMLCanvasElement)) return null;
                return el;
            }

            /* ---------- Destroy a chart instance ---------- */
            function destroyChart(id) {
                var ch = charts[id];
                if (ch) {
                    try { ch.destroy(); } catch (_) {}
                    delete charts[id];
                }
            }

            /* ---------- Create or update a chart ---------- */
            function createOrUpdateChart(id, config, dataFn) {
                var canvas = getCanvas(id);
                if (!canvas) return;

                if (charts[id]) {
                    var chart = charts[id];
                    var newData;
                    try { newData = dataFn(); } catch (_) { return; }
                    if (!newData || !newData.labels || !newData.datasets) return;

                    chart.data.labels = newData.labels;
                    newData.datasets.forEach(function (ds, i) {
                        if (chart.data.datasets[i]) {
                            chart.data.datasets[i].data = ds.data || [];
                            chart.data.datasets[i].label = ds.label;
                            if (ds.backgroundColor) chart.data.datasets[i].backgroundColor = ds.backgroundColor;
                            if (ds.borderColor) chart.data.datasets[i].borderColor = ds.borderColor;
                        }
                    });
                    chart.update('none');
                } else {
                    destroyChart(id);
                    var ctx = canvas.getContext('2d');
                    if (!ctx) return;
                    var cfg;
                    try { cfg = typeof config === 'function' ? config() : config; } catch (_) { return; }
                    cfg.options = cfg.options || {};
                    cfg.options.responsive = true;
                    cfg.options.maintainAspectRatio = false;
                    cfg.options.animation = cfg.options.animation || { duration: 300 };
                    cfg.options.font = { family: "'Inter', system-ui, sans-serif" };
                    try {
                        charts[id] = new Chart(ctx, cfg);
                    } catch (e) {
                        console.warn('Chart init failed for', id, e);
                    }
                }
            }

            /* ---------- Initialize all charts with data ---------- */
            function initCharts(data) {
                if (!data) return;

                    createOrUpdateChart('ticketsChart', function () {
                        return {
                            type: 'line',
                            data: {
                                labels: data.ticketsTrend.labels,
                                datasets: [
                                    { label: 'Created', data: data.ticketsTrend.created, borderColor: COLORS.primary, backgroundColor: COLORS.primaryLight, fill: true, tension: 0.3, pointRadius: 2, pointHoverRadius: 5, borderWidth: 2 },
                                    { label: 'Completed', data: data.ticketsTrend.completed, borderColor: COLORS.success, backgroundColor: 'transparent', fill: false, tension: 0.3, pointRadius: 3, pointHoverRadius: 6, borderWidth: 2.5 },
                                    { label: 'Delivered', data: data.ticketsTrend.delivered, borderColor: COLORS.warning, backgroundColor: 'transparent', fill: false, tension: 0.3, pointRadius: 3, pointHoverRadius: 6, borderWidth: 2.5 }
                                ]
                        },
                        options: {
                            responsive: true, maintainAspectRatio: false,
                            animation: { duration: 300 },
                            interaction: { mode: 'index', intersect: false },
                            plugins: {
                                legend: { display: false },
                                tooltip: { backgroundColor: '#1e293b', titleColor: '#fff', bodyColor: '#e2e8f0', padding: 12, cornerRadius: 8, displayColors: true }
                            },
                            scales: {
                                x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 11 }, maxTicksLimit: 12 } },
                                y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { color: '#94a3b8', font: { size: 11 } } }
                            }
                        }
                    };
                }, function () {
                    return {
                        labels: data.ticketsTrend.labels,
                        datasets: [
                            { label: 'Created', data: data.ticketsTrend.created, backgroundColor: COLORS.primaryLight, borderColor: COLORS.primary },
                            { label: 'Completed', data: data.ticketsTrend.completed, backgroundColor: COLORS.successLight, borderColor: COLORS.success },
                            { label: 'Delivered', data: data.ticketsTrend.delivered, backgroundColor: COLORS.warningLight, borderColor: COLORS.warning }
                        ]
                    };
                });

                createOrUpdateChart('miniRevenueChart', function () {
                    return {
                        type: 'line',
                        data: {
                            labels: data.revenueTrend.labels,
                            datasets: [{
                                data: data.revenueTrend.revenue, borderColor: COLORS.warning, backgroundColor: COLORS.warningLight, fill: true, tension: 0.4, pointRadius: 0, borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true, maintainAspectRatio: false,
                            animation: false,
                            plugins: { legend: { display: false }, tooltip: { enabled: false } },
                            scales: { x: { display: false }, y: { display: false, beginAtZero: true } },
                            elements: { point: { radius: 0 } }
                        }
                    };
                }, function () {
                    return {
                        labels: data.revenueTrend.labels,
                        datasets: [{ label: 'Revenue', data: data.revenueTrend.revenue }]
                    };
                });

                createOrUpdateChart('customersChart', function () {
                    var trend = data.customerTrend || {};
                    var labels = trend.labels || [];
                    var newData = trend.new || [];
                    var returning = trend.returning || [];
                    return {
                        type: 'bar',
                        data: {
                            labels: labels,
                            datasets: [
                                { label: 'New', data: newData, backgroundColor: COLORS.primary, borderRadius: 4, barPercentage: 0.6, categoryPercentage: 0.8 },
                                { label: 'Returning', data: returning, backgroundColor: COLORS.warning, borderRadius: 4, barPercentage: 0.6, categoryPercentage: 0.8 }
                            ]
                        },
                        options: {
                            responsive: true, maintainAspectRatio: false,
                            animation: { duration: 300 },
                            interaction: { mode: 'index', intersect: false },
                            plugins: {
                                legend: { display: false },
                                tooltip: { backgroundColor: '#1e293b', titleColor: '#fff', bodyColor: '#e2e8f0', padding: 12, cornerRadius: 8 }
                            },
                            scales: {
                                x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 10 }, maxTicksLimit: 8 } },
                                y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { color: '#94a3b8', font: { size: 10 } } }
                            }
                        }
                    };
                }, function () {
                    var trend = data.customerTrend || {};
                    return {
                        labels: trend.labels || [],
                        datasets: [
                            { label: 'New', data: trend.new || [], backgroundColor: COLORS.primary },
                            { label: 'Returning', data: trend.returning || [], backgroundColor: COLORS.warning }
                        ]
                    };
                });

                /* Completed vs Delivery chart (grouped bar) */
                createOrUpdateChart('deliveryChart', function () {
                    var completed = data.ticketsTrend.completed || [];
                    var delivered = data.ticketsTrend.delivered || [];
                    var labels = data.ticketsTrend.labels || [];
                    var hasData = labels.length > 0;

                    return {
                        type: 'bar',
                        data: {
                            labels: hasData ? labels : ['No Data'],
                            datasets: [
                                { label: 'Completed', data: hasData ? completed : [0], backgroundColor: COLORS.success, borderRadius: 4, barPercentage: 0.35, categoryPercentage: 0.7 },
                                { label: 'Delivered', data: hasData ? delivered : [0], backgroundColor: COLORS.primary, borderRadius: 4, barPercentage: 0.35, categoryPercentage: 0.7 }
                            ]
                        },
                        options: {
                            responsive: true, maintainAspectRatio: false,
                            animation: { duration: 300 },
                            interaction: { mode: 'index', intersect: false },
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#1e293b', titleColor: '#fff', bodyColor: '#e2e8f0', padding: 12, cornerRadius: 8,
                                    callbacks: {
                                        label: function (ctx) {
                                            return ctx.dataset.label + ': ' + ctx.parsed.y;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 10 }, maxTicksLimit: 15 } },
                                y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { color: '#94a3b8', font: { size: 10 }, stepSize: 1 } }
                            }
                        }
                    };
                }, function () {
                    var completed = data.ticketsTrend.completed || [];
                    var delivered = data.ticketsTrend.delivered || [];
                    var labels = data.ticketsTrend.labels || [];
                    var hasData = labels.length > 0;
                    return {
                        labels: hasData ? labels : ['No Data'],
                        datasets: [
                            { label: 'Completed', data: hasData ? completed : [0], backgroundColor: COLORS.success },
                            { label: 'Delivered', data: hasData ? delivered : [0], backgroundColor: COLORS.primary }
                        ]
                    };
                });

                /* Technician chart (special case - horizontal bar) */
                (function () {
                    var canvas = getCanvas('technicianChart');
                    if (!canvas) return;
                    var techData = data.technicianPerformance || [];
                    var techLabels = techData.map(function (t) { return t.technicianName; });
                    var techCompleted = techData.map(function (t) { return t.completedTickets; });
                    var techAssigned = techData.map(function (t) { return t.totalAssigned; });
                    var hasData = techLabels.length > 0;

                    if (charts.technicianChart) {
                        var ch = charts.technicianChart;
                        ch.data.labels = hasData ? techLabels : ['No Data'];
                        if (ch.data.datasets[0]) ch.data.datasets[0].data = hasData ? techCompleted : [0];
                        if (ch.data.datasets[1]) ch.data.datasets[1].data = hasData ? techAssigned : [0];
                        ch.update('none');
                    } else {
                        destroyChart('technicianChart');
                        var ctx = canvas.getContext('2d');
                        if (!ctx) return;
                        try {
                            charts.technicianChart = new Chart(ctx, {
                                type: 'bar',
                                data: {
                                    labels: hasData ? techLabels : ['No Data'],
                                    datasets: [
                                        { label: 'Completed', data: hasData ? techCompleted : [0], backgroundColor: COLORS.success, borderRadius: 4, barPercentage: 0.5, categoryPercentage: 0.7 },
                                        { label: 'Assigned', data: hasData ? techAssigned : [0], backgroundColor: 'rgba(0,119,182,0.25)', borderRadius: 4, barPercentage: 0.5, categoryPercentage: 0.7 }
                                    ]
                                },
                                options: {
                                     responsive: true, maintainAspectRatio: false,
                                    animation: { duration: 300 },
                                    interaction: { mode: 'index', intersect: false },
                                    font: { family: "'Inter', system-ui, sans-serif" },
                                    plugins: {
                                        legend: { position: 'top', labels: { boxWidth: 12, padding: 12, font: { size: 11 } } },
                                        tooltip: {
                                            backgroundColor: '#1e293b', titleColor: '#fff', bodyColor: '#e2e8f0', padding: 12, cornerRadius: 8,
                                            callbacks: {
                                                afterBody: function (tooltipItems) {
                                                    var idx = tooltipItems[0].dataIndex;
                                                    var t = techData[idx];
                                                    if (t) { return ['Completion Rate: ' + t.completionRate + '%', 'Revenue: ' + formatter.format(t.revenueGenerated)]; }
                                                    return [];
                                                }
                                            }
                                        }
                                    },
                                    scales: {
                                        x: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { color: '#94a3b8', font: { size: 11 } } },
                                        y: { grid: { display: false }, ticks: { color: '#64748b', font: { size: 10 } } }
                                    }
                                }
                            });
                        } catch (e) {
                            console.warn('Technician chart init failed', e);
                        }
                    }
                })();
            }


            function updateCards(data) {
                var setText = function (id, val) { var el = document.getElementById(id); if (el) el.textContent = val; };
                setText('totalTickets', data.totalTickets);
                setText('totalCustomers', data.totalCustomers);
                setText('totalRevenue', formatter.format(data.totalRevenue));
                setText('activeTechnicians', data.activeTechnicians);
                setText('readyForDelivery', data.ticketsReadyForDelivery);
                setText('pendingPayments', data.pendingPayments);
                setText('totalRevenueDisplay', formatter.format(data.totalRevenue));

                var growthEl = document.getElementById('revenueGrowth');
                if (growthEl) {
                    var gv = data.revenueGrowth;
                    growthEl.textContent = (gv >= 0 ? '+' : '') + gv.toFixed(1) + '%';
                    growthEl.className = 'fw-bold mb-0 ' + (gv >= 0 ? 'text-success' : 'text-danger');
                }
                setText('avgRevenuePerTicket', formatter.format(data.averageRevenuePerTicket));
                setText('newCustomers', data.newCustomers);
                setText('returningCustomers', data.returningCustomers);
                setText('totalCustomersDisplay', data.totalCustomers);
            }

            /* ---------- Date range helpers ---------- */
            function getDateRange(range) {
                var now = new Date();
                var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                var start, end;
                switch (range) {
                    case 'today': start = new Date(today); end = new Date(today); break;
                    case 'last7': start = new Date(today); start.setDate(start.getDate() - 6); end = new Date(today); break;
                    case 'last30': start = new Date(today); start.setDate(start.getDate() - 29); end = new Date(today); break;
                    case 'thismonth': start = new Date(today.getFullYear(), today.getMonth(), 1); end = new Date(today); break;
                }
                return { start: start, end: end };
            }

            function formatISODate(date) {
                return date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0') + '-' + String(date.getDate()).padStart(2, '0');
            }

            /* ---------- Load dashboard data via AJAX (presets only) ---------- */
            async function loadDashboard(range) {
                var rangeData = getDateRange(range);
                var startDate = formatISODate(rangeData.start);
                var endDate = formatISODate(rangeData.end);

                var buttons = document.querySelectorAll('.date-range-btn');
                buttons.forEach(function (b) { if (b.id !== 'customRangeBtn') { b.classList.remove('active'); } });
                var activeBtn = document.querySelector('.date-range-btn[data-range="' + range + '"]');
                if (activeBtn) activeBtn.classList.add('active');

                try {
                    var response = await fetch('/Home/GetDashboardData?startDate=' + startDate + '&endDate=' + endDate);
                    var data = await response.json();
                    updateCards(data);
                    initCharts(data);
                } catch (err) {
                    console.error('Dashboard load error:', err);
                }
            }

          
            var popoverEl = document.getElementById('customDatePopover');

            function hidePopover() {
                if (popoverEl) popoverEl.classList.add('d-none');
                var backdrop = document.querySelector('.popover-backdrop');
                if (backdrop) backdrop.remove();
            }

            function showPopover() {
                if (!popoverEl) return;
                popoverEl.classList.remove('d-none');
                // Set default dates
                var today = formatISODate(new Date());
                var sevenAgo = formatISODate(new Date(Date.now() - 6 * 86400000));
                document.getElementById('startDate').value = sevenAgo;
                document.getElementById('endDate').value = today;
                // Add backdrop
                if (!document.querySelector('.popover-backdrop')) {
                    var backdrop = document.createElement('div');
                    backdrop.className = 'popover-backdrop';
                    backdrop.addEventListener('click', hidePopover);
                    document.body.appendChild(backdrop);
                }
            }

            /* ---------- Error display ---------- */
            function showDateError(msg) {
                hidePopover();
                var container = document.getElementById('dateRangeCard');
                if (!container) return;
                var existing = document.getElementById('dateRangeError');
                if (existing) existing.remove();
                var div = document.createElement('div');
                div.id = 'dateRangeError';
                div.className = 'date-range-error px-3 pb-2';
                div.innerHTML = '<i class="bi bi-exclamation-circle"></i> ' + msg;
                container.appendChild(div);
                setTimeout(function () { var e = document.getElementById('dateRangeError'); if (e) e.remove(); }, 4000);
            }

            /* ---------- Event listeners ---------- */
            document.querySelectorAll('.date-range-btn').forEach(function (btn) {
                if (btn.id === 'customRangeBtn') return;
                btn.addEventListener('click', function () {
                    hidePopover();
                    loadDashboard(this.dataset.range);
                });
            });

            var customBtn = document.getElementById('customRangeBtn');
            if (customBtn) {
                customBtn.addEventListener('click', function () {
                    var isOpen = popoverEl && !popoverEl.classList.contains('d-none');
                    if (isOpen) { hidePopover(); return; }
                    showPopover();
                    document.querySelectorAll('.date-range-btn').forEach(function (b) { b.classList.remove('active'); });
                    customBtn.classList.add('active');
                });
            }

            var applyBtn = document.getElementById('applyCustomRange');
            if (applyBtn) {
                applyBtn.addEventListener('click', function () {
                    var start = document.getElementById('startDate').value;
                    var end = document.getElementById('endDate').value;

                    if (!start || !end) {
                        showDateError('Please select both start and end dates.');
                        return;
                    }
                    if (start > end) {
                        showDateError('Start date must be before or equal to end date.');
                        return;
                    }
                    // Reload page with custom date range parameters
                    window.location.href = '?range=custom&startDate=' + start + '&endDate=' + end;
                });
            }

            /* ---------- Init from server-rendered data ---------- */
            var initialDataEl = document.getElementById('initialData');
            if (initialDataEl) {
                try {
                    var initialData = JSON.parse(initialDataEl.textContent);
                    if (initialData) {
                        updateCards(initialData);
                        initCharts(initialData);
                    }
                } catch (e) {
                    console.warn('Failed to parse initial data', e);
                }
            }

            /* ---------- Throttled ResizeObserver (prevents flicker loop) ---------- */
            if (window.ResizeObserver) {
                var roTargets = document.querySelectorAll('.dashboard-chart-wrapper .chart-container, .analytics-row .chart-container');
                roTargets.forEach(function (container) {
                    var lastW = 0, lastH = 0, roTimer = null;
                    var ro = new ResizeObserver(function (entries) {
                        var entry = entries[0];
                        if (!entry) return;
                        var cr = entry.contentRect;
                        var w = Math.round(cr.width), h = Math.round(cr.height);
                        if (w < 10 || h < 10) return;
                        if (w === lastW && h === lastH) return;
                        lastW = w; lastH = h;
                        var canvas = container.querySelector('canvas');
                        if (!canvas || !canvas.id || !charts[canvas.id]) return;
                        var id = canvas.id;
                        if (roTimer) clearTimeout(roTimer);
                        roTimer = setTimeout(function () {
                            if (charts[id]) charts[id].resize();
                        }, 120);
                    });
                    ro.observe(container);
                });
            }
        })();
    </script>
}
