@model DeviceModel

@{
    ViewData["Title"] = "Edit Device";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-start border-success border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <span class="fw-medium">@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house-fill me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Report" class="text-decoration-none"><i class="bi bi-display me-1"></i>Devices</a></li>
            <li class="breadcrumb-item active fw-semibold" aria-current="page">Edit</li>
        </ol>
    </nav>
    <h3 class="fw-bold text-dark mb-0"><i class="bi bi-pencil-square fs-3 me-2 text-warning"></i>Edit Device</h3>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-warning text-dark rounded-top-4 py-3 px-4">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 bg-white bg-opacity-50 p-2 me-3">
                        <i class="bi bi-pencil-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-semibold">Device Information</h5>
                        <span class="small opacity-75">Update the device details below</span>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" novalidate>
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Name" class="form-control rounded-3" placeholder="Device Name" />
                                <label asp-for="Name"><i class="bi bi-tag-fill me-2 text-primary"></i>Device Name</label>
                                <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea asp-for="Description" class="form-control rounded-3" placeholder="Description" style="height: 120px"></textarea>
                                <label asp-for="Description"><i class="bi bi-card-text me-2 text-primary"></i>Description</label>
                                <span asp-validation-for="Description" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light border-0 rounded-3 p-3">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-3 bg-white shadow-sm p-2 me-3">
                                        <i class="bi bi-toggle-on fs-4 text-primary"></i>
                                    </div>
                                    <div class="form-check form-switch mb-0">
                                        <input asp-for="Status" class="form-check-input" role="switch" style="width: 3em; height: 1.5em;" />
                                        <label asp-for="Status" class="form-check-label fw-semibold ms-2"></label>
                                        <div class="text-muted small mt-1">
                                            <i class="bi bi-info-circle me-1"></i>Toggle to mark device as active or inactive
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Report" class="btn btn-outline-secondary rounded-3 px-4 py-2">
                            <i class="bi bi-arrow-left fs-5 me-1 align-middle"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-warning rounded-3 px-5 py-2 shadow-sm">
                            <i class="bi bi-check-lg fs-5 me-1 align-middle"></i>Update Device
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

