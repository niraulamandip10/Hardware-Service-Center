@model IEnumerable<TicketReportViewModel>
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Completed Tickets";
    var total = Model.Count();
    var completed = Model.Count(t => t.TicketStatus == TicketStatus.Completed);
    var delivered = Model.Count(t => t.TicketStatus == TicketStatus.Delevered);
    var totalAmount = Model.Sum(t => t.Amount ?? 0);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-start border-success border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <span class="fw-medium">@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Report" class="text-decoration-none"><i class="bi bi-ticket-detailed me-1"></i>Tickets</a></li>
                <li class="breadcrumb-item active fw-semibold" aria-current="page">Completed</li>
            </ol>
        </nav>
        <h2 class="mb-0 fw-bold text-dark"><i class="bi bi-check2-all fs-3 me-2 text-success"></i>Completed & Delivered Tickets</h2>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-success bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-check-circle fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Completed</p>
                    <h3 class="mb-0 fw-bold fs-1">@completed</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-dark bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-box-seam fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Delivered</p>
                    <h3 class="mb-0 fw-bold fs-1">@delivered</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-secondary bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-check2-all fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Total</p>
                    <h3 class="mb-0 fw-bold fs-1">@total</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-primary bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-currency-dollar fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Total Amount</p>
                    <h3 class="mb-0 fw-bold fs-1">@totalAmount.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white rounded-top-4 py-3 px-4 border-bottom">
        <div class="row align-items-center g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 rounded-start-3">
                        <i class="bi bi-search fs-5 text-muted"></i>
                    </span>
                    <input type="text" id="completedSearch" class="form-control border-start-0 ps-0 rounded-end-3" placeholder="Search completed tickets..." />
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                <span class="text-muted small fw-medium">
                    <i class="bi bi-layout-text-window me-1"></i>Showing <strong>@total</strong> ticket(s)
                </span>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="completedTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 fw-semibold text-muted" style="width: 60px;">S.N</th>
                        <th class="py-3 fw-semibold text-muted">Ticket No</th>
                        <th class="py-3 fw-semibold text-muted">Customer</th>
                        <th class="py-3 fw-semibold text-muted">Device</th>
                        <th class="py-3 fw-semibold text-muted">Technician</th>
                        <th class="text-end py-3 fw-semibold text-muted">Amount</th>
                        <th class="text-center py-3 fw-semibold text-muted">Payment</th>
                        <th class="text-center py-3 fw-semibold text-muted">Status</th>
                        <th class="text-center py-3 pe-4 fw-semibold text-muted">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="fw-semibold ps-4 text-muted py-3">@(i++)</td>
                                <td class="fw-semibold py-3">
                                    <span class="d-inline-block bg-success bg-opacity-10 text-success rounded-2 px-3 py-1">
                                        <i class="bi bi-ticket me-1"></i>@ticket.TicketNo
                                    </span>
                                </td>
                                <td class="py-3"><i class="bi bi-person-fill text-muted me-1"></i>@ticket.CustomerName</td>
                                <td class="py-3"><i class="bi bi-display text-muted me-1"></i>@ticket.DeviceName</td>
                                <td class="py-3">@(ticket.TechnicianName ?? "-")</td>
                                <td class="text-end py-3 fw-semibold">
                                    @if (ticket.Amount.HasValue)
                                    {
                                        <span class="text-dark">₹ @ticket.Amount.Value.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center py-3">
                                    @if (!string.IsNullOrEmpty(ticket.PaymentMethod))
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2 fw-semibold">
                                            @ticket.PaymentMethod
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center py-3">
                                    @if (ticket.TicketStatus == TicketStatus.Completed)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-semibold">
                                            <i class="bi bi-check-circle me-1"></i>Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark bg-opacity-10 text-dark rounded-pill px-3 py-2 fw-semibold">
                                            <i class="bi bi-box-seam me-1"></i>Delivered
                                        </span>
                                    }
                                </td>
                                <td class="text-center py-3 text-muted small">@ticket.RecDate.ToString("dd-MMM-yy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-check2-all text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">No Completed Tickets</h5>
                                    <p class="text-muted mb-0">Completed tickets will appear here.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
