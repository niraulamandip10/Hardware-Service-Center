@model TechnicianModel

@{
    ViewData["Title"] = "Create Technician";
}

<div class="page-content">

    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Report"><i class="bi bi-person-wrench me-1"></i>Technicians</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Create</li>
                </ol>
            </nav>
            <h3 class="fw-bold mb-0"><i class="bi bi-person-wrench-fill me-2 text-primary"></i>Create Technician</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="theme-card">
                <div class="theme-card-header">
                    <div class="header-icon">
                        <i class="bi bi-person-wrench-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Register New Technician</h5>
                        <small>Fill in the details below to add a new technician</small>
                    </div>
                </div>
                <div class="theme-card-body">
                    <form asp-action="Create" method="post" novalidate>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Name" class="form-control" placeholder="Full Name" />
                                    <label asp-for="Name"></label>
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Code" class="form-control" placeholder="Technician Code" />
                                    <label asp-for="Code"></label>
                                    <span asp-validation-for="Code" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating mb-3">
                                    <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 120px"></textarea>
                                    <label asp-for="Description"></label>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Report" class="btn-secondary-outline px-4">
                                <i class="bi bi-arrow-left"></i>Cancel
                            </a>
                            <button type="submit" class="btn-primary-blue px-5">
                                <i class="bi bi-check-lg"></i>Save
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
