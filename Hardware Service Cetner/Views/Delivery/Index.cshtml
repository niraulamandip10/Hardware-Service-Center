@model IEnumerable<TicketReportViewModel>
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Pending Deliveries";
    var total = Model.Count();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-start border-success border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <span class="fw-medium">@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-start border-danger border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <span class="fw-medium">@TempData["Error"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Delivery" asp-action="Report" class="text-decoration-none"><i class="bi bi-box-seam me-1"></i>Delivery</a></li>
                <li class="breadcrumb-item active fw-semibold" aria-current="page">Pending Deliveries</li>
            </ol>
        </nav>
        <h2 class="mb-0 fw-bold text-dark"><i class="bi bi-truck fs-3 me-2 text-warning"></i>Pending Deliveries</h2>
    </div>
    <a asp-controller="Delivery" asp-action="Report" class="btn btn-outline-secondary btn-lg shadow-sm rounded-3 px-4">
        <i class="bi bi-clock-history fs-5 me-2 align-middle"></i>Delivery Report
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-warning bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-truck fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Pending Delivery</p>
                    <h3 class="mb-0 fw-bold fs-1">@total</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-success bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-check2-all fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Completed</p>
                    <h3 class="mb-0 fw-bold fs-1">@ViewBag.DeliveredCount</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-info bg-gradient text-white">
            <div class="card-body d-flex align-items-center p-4">
                <div class="rounded-3 bg-white bg-opacity-25 p-3 me-3">
                    <i class="bi bi-box-seam fs-2"></i>
                </div>
                <div>
                    <p class="mb-0 fs-6 fw-medium opacity-75">Ready to Deliver</p>
                    <h3 class="mb-0 fw-bold fs-1">@total</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white rounded-top-4 py-3 px-4 border-bottom">
        <div class="row align-items-center g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 rounded-start-3">
                        <i class="bi bi-search fs-5 text-muted"></i>
                    </span>
                    <input type="text" id="deliverySearch" class="form-control border-start-0 ps-0 rounded-end-3" placeholder="Search by ticket no, customer, device..." />
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                <span class="text-muted small fw-medium">
                    <i class="bi bi-layout-text-window me-1"></i>Showing <strong>@total</strong> ticket(s) pending delivery
                </span>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="pendingDeliveryTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 fw-semibold text-muted" style="width: 60px;">S.N</th>
                        <th class="py-3 fw-semibold text-muted">Ticket No</th>
                        <th class="py-3 fw-semibold text-muted">Customer</th>
                        <th class="py-3 fw-semibold text-muted">Device</th>
                        <th class="py-3 fw-semibold text-muted">Technician</th>
                        <th class="text-center py-3 fw-semibold text-muted">Completed Date</th>
                        <th class="text-center py-3 pe-4 fw-semibold text-muted" style="width: 160px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="fw-semibold ps-4 text-muted py-3">@(i++)</td>
                                <td class="fw-semibold py-3">
                                    <span class="d-inline-block bg-warning bg-opacity-10 text-warning rounded-2 px-3 py-1">
                                        <i class="bi bi-ticket me-1"></i>@ticket.TicketNo
                                    </span>
                                </td>
                                <td class="py-3"><i class="bi bi-person-fill text-muted me-1"></i>@ticket.CustomerName</td>
                                <td class="py-3"><i class="bi bi-display text-muted me-1"></i>@ticket.DeviceName</td>
                                <td class="py-3">
                                    @if (!string.IsNullOrEmpty(ticket.TechnicianName))
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2 fw-semibold">
                                            <i class="bi bi-person-gear me-1"></i>@ticket.TechnicianName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center py-3 text-muted small">@ticket.RecDate.ToString("dd-MMM-yy")</td>
                                <td class="text-center py-3 pe-4">
                                    <a asp-action="Checkout" asp-route-ticketId="@ticket.Id"
                                       class="btn btn-sm btn-warning rounded-3 px-3 fw-semibold shadow-sm">
                                        <i class="bi bi-truck fs-5 me-1 align-middle"></i>Deliver Now
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-check2-all text-success" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">All Clear!</h5>
                                    <p class="text-muted mb-0">No tickets pending delivery at the moment.</p>
                                    <a asp-controller="Ticket" asp-action="Report" class="btn btn-primary mt-3 rounded-3 px-4">
                                        <i class="bi bi-ticket-detailed me-2"></i>View Tickets
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deliverySearch')?.addEventListener('keyup', function () {
            const value = this.value.toLowerCase();
            document.querySelectorAll('#pendingDeliveryTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? '' : 'none';
            });
        });
    </script>
}
