@model AccountModel

@{
    ViewData["Title"] = "Edit Account";
}

<div class="page-content">

    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Report"><i class="bi bi-people-fill me-1"></i>Accounts</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Edit</li>
                </ol>
            </nav>
            <h3 class="fw-bold mb-0"><i class="bi bi-pencil-fill me-2 text-warning"></i>Edit Account</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="theme-card">
                <div class="theme-card-header">
                    <div class="header-icon bg-warning text-dark">
                        <i class="bi bi-pencil-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Edit Account</h5>
                        <small>Update the account details below</small>
                    </div>
                </div>
                <div class="theme-card-body">
                    <form asp-action="Edit" method="post" novalidate>
                        <input type="hidden" asp-for="Id" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Name" class="form-control" placeholder="Full Name" />
                                    <label asp-for="Name"></label>
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Username" class="form-control" placeholder="Username" />
                                    <label asp-for="Username"></label>
                                    <span asp-validation-for="Username" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Email" class="form-control" placeholder="Email Address" />
                                    <label asp-for="Email"></label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Phone" class="form-control" placeholder="Phone Number" />
                                    <label asp-for="Phone"></label>
                                    <span asp-validation-for="Phone" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating mb-3">
                                    <input asp-for="Address" class="form-control" placeholder="Address" />
                                    <label asp-for="Address"></label>
                                    <span asp-validation-for="Address" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Report" class="btn-secondary-outline px-4">
                                <i class="bi bi-arrow-left"></i>Cancel
                            </a>
                            <button type="submit" class="btn-warning px-5">
                                <i class="bi bi-check-lg"></i>Update
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
