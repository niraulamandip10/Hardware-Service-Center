<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hardware Service Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hardware_Service_Cetner.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-hsc">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tools me-2"></i>Hardware Service Center
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    @{
                        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
                        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
                        bool IsActive(string ctrl, string action = null) => string.Equals(currentController, ctrl, StringComparison.OrdinalIgnoreCase) && (action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));
                        bool IsTicketSection() => string.Equals(currentController, "Ticket", StringComparison.OrdinalIgnoreCase);
                        bool IsDeliverySection() => string.Equals(currentController, "Delivery", StringComparison.OrdinalIgnoreCase);
                    }
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Home") ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(IsTicketSection() ? "active" : "")" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-ticket-detailed me-1"></i>Tickets
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @(IsActive("Ticket", "Report") ? "active" : "")" asp-area="" asp-controller="Ticket" asp-action="Report"><i class="bi bi-list-ul me-2"></i>All Tickets</a></li>
                                <li><a class="dropdown-item @(IsActive("Ticket", "Create") ? "active" : "")" asp-area="" asp-controller="Ticket" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>New Ticket</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item @(IsActive("Ticket", "Assigned") ? "active" : "")" asp-area="" asp-controller="Ticket" asp-action="Assigned"><i class="bi bi-person-check me-2"></i>Assigned</a></li>
                                <li><a class="dropdown-item @(IsActive("Ticket", "Completed") ? "active" : "")" asp-area="" asp-controller="Ticket" asp-action="Completed"><i class="bi bi-check2-all me-2"></i>Completed</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Customer") ? "active" : "")" asp-area="" asp-controller="Customer" asp-action="Report">
                                <i class="bi bi-people-fill me-1"></i>Customers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Device") ? "active" : "")" asp-area="" asp-controller="Device" asp-action="Report">
                                <i class="bi bi-display-fill me-1"></i>Devices
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Technician") ? "active" : "")" asp-area="" asp-controller="Technician" asp-action="Report">
                                <i class="bi bi-person-gear me-1"></i>Technicians
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(IsDeliverySection() ? "active" : "")" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-box-seam me-1"></i>Delivery
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @(IsActive("Delivery", "Index") ? "active" : "")" asp-area="" asp-controller="Delivery" asp-action="Index"><i class="bi bi-truck me-2"></i>Pending Deliveries</a></li>
                                <li><a class="dropdown-item @(IsActive("Delivery", "Report") ? "active" : "")" asp-area="" asp-controller="Delivery" asp-action="Report"><i class="bi bi-clock-history me-2"></i>Delivery Report</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Account") ? "active" : "")" asp-area="" asp-controller="Account" asp-action="Report">
                                <i class="bi bi-person-badge-fill me-1"></i>Accounts
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <!-- Quick Actions Dropdown -->
                        <div class="dropdown">
                            <button class="btn quick-actions-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-lightning-charge-fill"></i>Quick Actions
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Ticket" asp-action="Create">
                                        <i class="bi bi-plus-circle-fill me-2 text-primary"></i>Create Ticket
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Ticket" asp-action="Report">
                                        <i class="bi bi-file-earmark-bar-graph-fill me-2 text-success"></i>Ticket Report
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Customer" asp-action="Create">
                                        <i class="bi bi-person-plus-fill me-2 text-info"></i>New Customer
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Device" asp-action="Create">
                                        <i class="bi bi-plus-square-fill me-2 text-warning"></i>New Device
                                    </a>
                                </li>
                            </ul>
                          </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="@(ViewBag.FluidLayout == true ? "container-fluid px-4" : "container")">
        <main role="main" class="py-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
