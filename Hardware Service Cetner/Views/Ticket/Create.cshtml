@model TicketModel

@{
    ViewData["Title"] = "Create Ticket";
}

<div class="page-content">

    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Report"><i class="bi bi-ticket-detailed me-1"></i>Tickets</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Create</li>
                </ol>
            </nav>
            <h3 class="fw-bold mb-0"><i class="bi bi-plus-circle-fill me-2 text-primary"></i>Register New Ticket</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <div class="theme-card">
                <div class="theme-card-header">
                    <div class="header-icon">
                        <i class="bi bi-ticket-detailed-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Ticket Information</h5>
                        <small>Fill in the details below to create a new service ticket</small>
                    </div>
                </div>
                <div class="theme-card-body">
                    <form asp-action="Create" method="post" novalidate>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="CustomerId" class="form-select form-control-custom" asp-items="@(new SelectList(ViewBag.getCustomer, "Id", "Name"))">
                                        <option value="">-- Select Customer --</option>
                                    </select>
                                    <label asp-for="CustomerId"><i class="bi bi-person-fill me-2 text-primary"></i>Customer</label>
                                    <span asp-validation-for="CustomerId" class="text-danger small mt-1"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="DeviceId" class="form-select form-control-custom" asp-items="@(new SelectList(ViewBag.getDevice, "Id", "Name"))">
                                        <option value="">-- Select Device --</option>
                                    </select>
                                    <label asp-for="DeviceId"><i class="bi bi-display-fill me-2 text-primary"></i>Device</label>
                                    <span asp-validation-for="DeviceId" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="RecById" class="form-select form-control-custom" asp-items="@(new SelectList(ViewBag.getRecById, "Id", "Name"))">
                                        <option value="">-- Select Received By --</option>
                                    </select>
                                    <label asp-for="RecById"><i class="bi bi-person-badge-fill me-2 text-primary"></i>Received By</label>
                                    <span asp-validation-for="RecById" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="TicketDescription" class="form-control form-control-custom" placeholder="Ticket Description" style="height: 120px"></textarea>
                                    <label asp-for="TicketDescription"><i class="bi bi-card-text me-2 text-primary"></i>Ticket Description</label>
                                    <span asp-validation-for="TicketDescription" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card bg-light border-0 rounded-3 p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-3 bg-white shadow-sm p-2 me-3">
                                            <i class="bi bi-calendar-date fs-4 text-primary"></i>
                                        </div>
                                        <div>
                                            <span class="text-muted small">Received Date</span>
                                            <div class="fw-semibold">@DateTime.Now.ToString("dd MMM yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Report" class="btn-secondary-outline px-4">
                                <i class="bi bi-arrow-left"></i>Back to List
                            </a>
                            <button type="submit" class="btn-primary-blue px-5">
                                <i class="bi bi-check-lg"></i>Save Ticket
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
