@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Hardware Service Center</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Hardware_Service_Cetner.styles.css" asp-append-version="true"/>
    <style>
        body {
            background: linear-gradient(135deg, #f4f7fc 0%, #e8f0fe 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', system-ui, sans-serif;
        }
        .login-container {
            width: 100%;
            padding: 1rem;
        }
    </style>
</head>

<body>
    <div class="login-container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-white shadow-sm p-3 mb-3" style="width: 72px; height: 72px;">
                        <i class="bi bi-tools fs-2" style="color: #0077B6;"></i>
                    </div>
                    <h3 class="fw-bold mb-0" style="color: #1e293b;">Hardware Service Center</h3>
                    <p class="text-muted small">Sign in to your account</p>
                </div>
                <div class="theme-card">
                    <div class="theme-card-body">
                        @if (ViewBag.Error != null)
                        {
                            <div class="theme-alert alert-danger mb-4" role="alert">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span class="fw-medium">@ViewBag.Error</span>
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <form asp-action="Login" method="post" novalidate>
                            <div class="form-floating mb-3">
                                <input asp-for="Username" class="form-control form-control-custom" placeholder="Username" />
                                <label asp-for="Username"><i class="bi bi-person-fill me-2 text-primary"></i>Username</label>
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                            <div class="form-floating mb-3">
                                <input asp-for="Password" class="form-control form-control-custom" placeholder="Password" />
                                <label asp-for="Password"><i class="bi bi-lock-fill me-2 text-primary"></i>Password</label>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn-primary-blue w-100 justify-content-center py-2 mt-3">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <a asp-controller="Account" asp-action="Create" class="text-decoration-none small">
                                <i class="bi bi-person-plus me-1"></i> Don't have an account? Register
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>