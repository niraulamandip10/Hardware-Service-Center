@model IEnumerable<TechnicianModel>

@{
    ViewData["Title"] = "Technicians";
    var total = Model.Count();
}

<div class="page-content">
    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="theme-alert alert-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span class="fw-medium">@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Technicians</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-tools me-2 text-primary"></i>All Technicians</h2>
        </div>
        <div class="header-actions">
            <a asp-action="Create" class="btn-primary-blue">
                <i class="bi bi-plus-circle-fill"></i>Add New Technician
            </a>
        </div>
    </div>

    <div class="theme-table-wrapper">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" id="technicianSearch" placeholder="Search..." />
            </div>
            <span class="text-muted small fw-medium">
                <i class="bi bi-layout-text-window me-1"></i>Showing <strong>@total</strong> record(s)
            </span>
        </div>
        <div class="table-responsive">
            <table class="table-custom" id="technicianTable">
                <thead>
                    <tr>
                        <th>S.N</th>
                        <th>@Html.DisplayNameFor(m => m.Name)</th>
                        <th>@Html.DisplayNameFor(m => m.Code)</th>
                        <th>@Html.DisplayNameFor(m => m.Description)</th>
                        <th>@Html.DisplayNameFor(m => m.RecDate)</th>
                        <th class="text-center">@Html.DisplayNameFor(m => m.IsActive)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var tech in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-muted">@(i++)</td>
                                <td class="fw-medium">@tech.Name</td>
                                <td>@tech.Code</td>
                                <td>@(tech.Description ?? "-")</td>
                                <td>@tech.RecDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-center">
                                    @if (tech.IsActive)
                                    {
                                        <span class="badge-custom badge-completed"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-pending"><i class="bi bi-x-circle-fill me-1"></i>Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@tech.Id" class="btn-secondary-outline btn-sm" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" asp-route-id="@tech.Id" class="d-inline">
                                        <button type="submit" class="btn-secondary-outline btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this technician?')" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('technicianSearch')?.addEventListener('keyup', function () {
            const value = this.value.toLowerCase();
            document.querySelectorAll('#technicianTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? '' : 'none';
            });
        });
    </script>
}
