@model IEnumerable<TicketReportViewModel>
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Completed Tickets";
    var total = Model.Count();
    var completed = Model.Count(t => t.TicketStatus == TicketStatus.Completed);
    var delivered = Model.Count(t => t.TicketStatus == TicketStatus.Delevered);
    var totalAmount = Model.Sum(t => t.Amount ?? 0);
}

<div class="page-content">

    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Report"><i class="bi bi-ticket-detailed me-1"></i>Tickets</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Completed</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-check2-all me-2 text-primary"></i>Completed & Delivered Tickets</h2>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(16,185,129,0.12); color: #10b981;">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div>
                        <p class="stat-label">Completed</p>
                        <p class="stat-value">@completed</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(100,116,139,0.12); color: #64748b;">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div>
                        <p class="stat-label">Delivered</p>
                        <p class="stat-value">@delivered</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(107,114,128,0.12); color: #6b7280;">
                        <i class="bi bi-check2-all"></i>
                    </div>
                    <div>
                        <p class="stat-label">Total</p>
                        <p class="stat-value">@total</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(0,119,182,0.12); color: #0077B6;">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                    <div>
                        <p class="stat-label">Total Amount</p>
                        <p class="stat-value">@totalAmount.ToString("N2")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="theme-table-wrapper">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" id="completedSearch" placeholder="Search completed tickets..." />
            </div>
            <span class="text-muted small fw-medium">
                <i class="bi bi-layout-text-window me-1"></i>
                Showing <strong>@total</strong> ticket(s)
            </span>
        </div>
        <div class="table-responsive">
            <table class="table-custom" id="completedTable">
                <thead>
                    <tr>
                        <th style="width: 60px;">S.N</th>
                        <th>Ticket No</th>
                        <th>Customer</th>
                        <th>Device</th>
                        <th>Technician</th>
                        <th class="text-end">Amount</th>
                        <th class="text-center">Payment</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-muted">@(i++)</td>
                                <td class="fw-semibold">
                                    <span class="badge-custom badge-completed"><i class="bi bi-ticket me-1"></i>@ticket.TicketNo</span>
                                </td>
                                <td><i class="bi bi-person-fill text-muted me-1"></i>@ticket.CustomerName</td>
                                <td><i class="bi bi-display text-muted me-1"></i>@ticket.DeviceName</td>
                                <td>@(ticket.TechnicianName ?? "-")</td>
                                <td class="text-end fw-semibold">
                                    @if (ticket.Amount.HasValue)
                                    {
                                        <span>₹ @ticket.Amount.Value.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(ticket.PaymentMethod))
                                    {
                                        <span class="badge-custom badge-assigned" style="background:rgba(6, 182, 212, 0.12);color:#0891B2">@ticket.PaymentMethod</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (ticket.TicketStatus == TicketStatus.Completed)
                                    {
                                        <span class="badge-custom badge-completed"><i class="bi bi-check-circle me-1"></i>Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-delivered"><i class="bi bi-box-seam me-1"></i>Delivered</span>
                                    }
                                </td>
                                <td class="text-center text-muted small">@ticket.RecDate.ToString("dd-MMM-yy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-check2-all text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">No Completed Tickets</h5>
                                    <p class="text-muted mb-0">Completed tickets will appear here.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('completedSearch')?.addEventListener('keyup', function () {
            const value = this.value.toLowerCase();
            document.querySelectorAll('#completedTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? '' : 'none';
            });
        });
    </script>
}
