@model DeliveryModel
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Delivery Checkout";
}

<div class="page-content">

    @if (TempData["Error"] != null)
    {
        <div class="theme-alert alert-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span class="fw-medium">@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index"><i class="bi bi-truck me-1"></i>Pending Deliveries</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Checkout</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-cart-check me-2 text-primary"></i>Delivery Checkout</h2>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="theme-card">
                <div class="theme-card-header">
                    <div class="header-icon">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Complete Delivery</h5>
                        <small>Fill in the delivery details below</small>
                    </div>
                </div>
                <div class="theme-card-body">
                    <form asp-action="Checkout" method="post" novalidate>
                        <input type="hidden" asp-for="TicketId" value="@Model.TicketId" />

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="UserId" class="form-control form-control-custom" placeholder="User ID" />
                                    <label asp-for="UserId"><i class="bi bi-person-badge-fill me-2 text-primary"></i>User ID</label>
                                    <span asp-validation-for="UserId" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="RecDate" class="form-control form-control-custom" type="date"
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                    <label asp-for="RecDate"><i class="bi bi-calendar-date me-2 text-primary"></i>Delivery Date</label>
                                    <span asp-validation-for="RecDate" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Amount" class="form-control form-control-custom" placeholder="0.00" type="number" step="0.01" />
                                    <label asp-for="Amount"><i class="bi bi-currency-dollar me-2 text-primary"></i>Amount</label>
                                    <span asp-validation-for="Amount" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="PaymentMethod" class="form-select form-control-custom">
                                        <option value="">-- Select Payment --</option>
                                        <option value="Cash">Cash</option>
                                        <option value="Card">Card</option>
                                        <option value="UPI">UPI</option>
                                        <option value="Bank Transfer">Bank Transfer</option>
                                    </select>
                                    <label asp-for="PaymentMethod"><i class="bi bi-credit-card me-2 text-primary"></i>Payment Method</label>
                                    <span asp-validation-for="PaymentMethod" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Remarks" class="form-control form-control-custom" placeholder="Remarks" style="height: 100px"></textarea>
                                    <label asp-for="Remarks"><i class="bi bi-chat-dots me-2 text-primary"></i>Remarks</label>
                                    <span asp-validation-for="Remarks" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn-secondary-outline px-4">
                                <i class="bi bi-arrow-left"></i>Back
                            </a>
                            <button type="submit" class="btn-primary-blue px-5">
                                <i class="bi bi-check-lg"></i>Confirm Delivery
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
