@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard">

    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1 text-dark">
                <i class="bi bi-grid-1x2-fill me-2 text-primary"></i>Dashboard
            </h1>
            
        </div>

        <div class="card border-0 shadow-sm rounded-4 flex-shrink-0" id="dateRangeCard" style="position:relative">
            <div class="card-body py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-calendar-range text-muted"></i>
                    <div class="d-flex flex-wrap gap-1" id="dateRangeGroup" role="group">
                        <button type="button" class="btn btn-sm rounded-pill date-range-btn" data-range="today">Today</button>
                        <button type="button" class="btn btn-sm rounded-pill date-range-btn active" data-range="last7">7 Days</button>
                        <button type="button" class="btn btn-sm rounded-pill date-range-btn" data-range="last30">30 Days</button>
                        <button type="button" class="btn btn-sm rounded-pill date-range-btn" data-range="thismonth">Month</button>
                        <button type="button" class="btn btn-sm rounded-pill date-range-btn" id="customRangeBtn">Custom</button>
                    </div>
                    <div class="date-range-popover d-none" id="customDatePopover">
                        <div class="d-flex flex-column gap-2">
                            <label for="startDate">Start Date</label>
                            <input type="date" class="form-control form-control-sm" id="startDate">
                            <label for="endDate">End Date</label>
                            <input type="date" class="form-control form-control-sm" id="endDate">
                            <button type="button" class="btn btn-primary btn-sm" id="applyCustomRange">
                                <i class="bi bi-check-lg me-1"></i>Apply
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4" id="kpiCards">
        <div class="col-xl-2 col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card" data-color="primary">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="kpi-icon rounded-3 me-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-ticket-detailed fs-4"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 text-muted small fw-medium text-truncate">Total Tickets</p>
                            <h3 class="mb-0 fw-bold kpi-value" id="totalTickets">@Model.TotalTickets</h3>
                        </div>
                    </div>
                    <div class="mt-2 d-flex align-items-center text-muted small">
                        <i class="bi bi-arrow-up-short me-1 text-success"></i>
                        <span>In selected period</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card" data-color="success">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="kpi-icon rounded-3 me-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-people-fill fs-4"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 text-muted small fw-medium text-truncate">Total Customers</p>
                            <h3 class="mb-0 fw-bold kpi-value" id="totalCustomers">@Model.TotalCustomers</h3>
                        </div>
                    </div>
                    <div class="mt-2 d-flex align-items-center text-muted small">
                        <i class="bi bi-arrow-up-short me-1 text-success"></i>
                        <span>Served in period</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card" data-color="warning">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="kpi-icon rounded-3 me-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-currency-dollar fs-4"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 text-muted small fw-medium text-truncate">Total Revenue</p>
                            <h3 class="mb-0 fw-bold kpi-value" id="totalRevenue">Rs @Model.TotalRevenue.ToString("N2")</h3>
                        </div>
                    </div>
                    <div class="mt-2 d-flex align-items-center text-muted small">
                        <i class="bi bi-arrow-up-short me-1 text-success"></i>
                        <span>Rs @(Model.AverageRevenuePerTicket.ToString("N2")) avg / ticket</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card" data-color="info">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="kpi-icon rounded-3 me-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-person-gear fs-4"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 text-muted small fw-medium text-truncate">Active Technicians</p>
                            <h3 class="mb-0 fw-bold kpi-value" id="activeTechnicians">@Model.ActiveTechnicians</h3>
                        </div>
                    </div>
                    <div class="mt-2 d-flex align-items-center text-muted small">
                        <i class="bi bi-person-check me-1 text-info"></i>
                        <span>Currently active</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card" data-color="purple">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="kpi-icon rounded-3 me-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-box-seam fs-4"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 text-muted small fw-medium text-truncate">Ready for Delivery</p>
                            <h3 class="mb-0 fw-bold kpi-value" id="readyForDelivery">@Model.TicketsReadyForDelivery</h3>
                        </div>
                    </div>
                    <div class="mt-2 d-flex align-items-center text-muted small">
                        <i class="bi bi-truck me-1 text-purple"></i>
                        <span>Completed, pending delivery</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card" data-color="danger">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="kpi-icon rounded-3 me-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-credit-card-2-back fs-4"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 text-muted small fw-medium text-truncate">Pending Payments</p>
                            <h3 class="mb-0 fw-bold kpi-value" id="pendingPayments">@Model.PendingPayments</h3>
                        </div>
                    </div>
                    <div class="mt-2 d-flex align-items-center text-muted small">
                        <i class="bi bi-clock me-1 text-danger"></i>
                        <span>Awaiting payment</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-7">
            <div class="dashboard-chart-wrapper">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white rounded-top-4 py-3 px-4 border-bottom d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0 fw-bold"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Tickets Analytics</h5>
                            <p class="mb-0 text-muted small">Ticket creation, completion, and delivery trends</p>
                        </div>
                        <div class="d-flex gap-3 small">
                            <span class="d-flex align-items-center"><span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#0077B6"></span> Created</span>
                            <span class="d-flex align-items-center"><span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#10b981"></span> Completed</span>
                            <span class="d-flex align-items-center"><span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#f59e0b"></span> Delivered</span>
                        </div>
                    </div>
                    <div class="card-body-chart">
                        <div class="chart-container">
                            <canvas id="ticketsChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="dashboard-chart-wrapper">
                <div class="card border-0 shadow-sm rounded-4 revenue-compact">
                    <div class="card-header bg-white rounded-top-4 py-2 px-4 border-bottom">
                        <h5 class="mb-0 fw-bold fs-6"><i class="bi bi-currency-exchange me-2 text-warning"></i>Revenue Overview</h5>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="text-center mb-2">
                            <p class="text-muted small fw-medium mb-0">Total Revenue</p>
                            <h2 class="fw-bold mb-0 display-5 text-dark" id="totalRevenueDisplay">Rs @Model.TotalRevenue.ToString("N2")</h2>
                        </div>
                        <div class="row g-1 text-center">
                            <div class="col-6">
                                <div class="bg-light rounded-3 p-2">
                                    <p class="text-muted small fw-medium mb-0">Growth</p>
                                    <h4 class="fw-bold mb-0 @(Model.RevenueGrowth >= 0 ? "text-success" : "text-danger")" id="revenueGrowth">
                                        @(Model.RevenueGrowth >= 0 ? "+" : "")@Model.RevenueGrowth.ToString("N1")%
                                    </h4>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded-3 p-2">
                                    <p class="text-muted small fw-medium mb-0">Avg / Ticket</p>
                                    <h4 class="fw-bold mb-0 text-dark" id="avgRevenuePerTicket">@(Model.AverageRevenuePerTicket.ToString("N2"))</h4>
                                </div>
                            </div>
                        </div>
                        <div class="mt-2 chart-container" style="height:50px">
                            <canvas id="miniRevenueChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

   
