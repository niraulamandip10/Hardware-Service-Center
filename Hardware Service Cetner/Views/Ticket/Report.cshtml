@model IEnumerable<TicketReportViewModel>
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "All Tickets";
    var total = Model.Count();
    var pending = Model.Count(t => t.TicketStatus == TicketStatus.Pending);
    var assigned = Model.Count(t => t.TicketStatus == TicketStatus.Assigned);
    var completed = Model.Count(t => t.TicketStatus == TicketStatus.Completed || t.TicketStatus == TicketStatus.Delevered);
}

<div class="page-content">

    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="theme-alert alert-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span class="fw-medium">@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Tickets</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-ticket-detailed fs-3 me-2 text-primary"></i>All Tickets</h2>
        </div>
        <div class="header-actions">
            <a asp-action="Create" class="btn-primary-blue">
                <i class="bi bi-plus-circle-fill"></i>New Ticket
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(0,119,182,0.12); color: #0077B6;">
                        <i class="bi bi-ticket-detailed"></i>
                    </div>
                    <div>
                        <p class="stat-label">Total Tickets</p>
                        <p class="stat-value">@total</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(245,158,11,0.12); color: #f59e0b;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <p class="stat-label">Pending</p>
                        <p class="stat-value">@pending</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(6,182,212,0.12); color: #06b6d4;">
                        <i class="bi bi-person-check"></i>
                    </div>
                    <div>
                        <p class="stat-label">Assigned</p>
                        <p class="stat-value">@assigned</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(16,185,129,0.12); color: #10b981;">
                        <i class="bi bi-check2-all"></i>
                    </div>
                    <div>
                        <p class="stat-label">Completed</p>
                        <p class="stat-value">@completed</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="theme-table-wrapper">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" id="ticketSearch" placeholder="Search by ticket no, customer, device..." />
            </div>
            <span class="text-muted small fw-medium">
                <i class="bi bi-layout-text-window me-1"></i>
                Showing <strong>@total</strong> ticket(s)
            </span>
        </div>
        <div class="table-responsive">
            <table class="table-custom" id="ticketTable">
                <thead>
                    <tr>
                        <th style="width: 50px;">S.N</th>
                        <th>Ticket No</th>
                        <th>Customer</th>
                        <th>Device</th>
                        <th>Received By</th>
                        <th>Assigned To</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Date</th>
                        <th class="text-center" style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-muted">@(i++)</td>
                                <td class="fw-semibold">
                                    <span class="badge-custom badge-pending">
                                        <i class="bi bi-ticket me-1"></i>@ticket.TicketNo
                                    </span>
                                </td>
                                <td><i class="bi bi-person-fill text-muted me-1"></i>@ticket.CustomerName</td>
                                <td><i class="bi bi-display text-muted me-1"></i>@ticket.DeviceName</td>
                                <td>@(ticket.ReceivedByName ?? "-")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(ticket.TechnicianName))
                                    {
                                        <span class="badge-custom badge-assigned">
                                            <i class="bi bi-person-gear me-1"></i>@ticket.TechnicianName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @switch (ticket.TicketStatus)
                                    {
                                        case TicketStatus.Pending:
                                            <span class="badge-custom badge-pending"><i class="bi bi-clock me-1"></i>Pending</span>
                                            break;
                                        case TicketStatus.Assigned:
                                            <span class="badge-custom badge-assigned"><i class="bi bi-person-check me-1"></i>Assigned</span>
                                            break;
                                        case TicketStatus.Repairing:
                                            <span class="badge-custom badge-repairing"><i class="bi bi-tools me-1"></i>Repairing</span>
                                            break;
                                        case TicketStatus.Completed:
                                            <span class="badge-custom badge-completed"><i class="bi bi-check-circle me-1"></i>Completed</span>
                                            break;
                                        case TicketStatus.Delevered:
                                            <span class="badge-custom badge-delivered"><i class="bi bi-box-seam me-1"></i>Delivered</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center text-muted small">@ticket.RecDate.ToString("dd-MMM-yy")</td>
                                <td class="text-center">
                                    @if (ticket.TicketStatus == TicketStatus.Pending)
                                    {
                                        <a asp-action="Assign" asp-route-id="@ticket.Id"
                                           class="btn-primary-blue btn-sm">
                                            <i class="bi bi-person-plus-fill me-1"></i>Assign
                                        </a>
                                    }
                                    else if (ticket.TicketStatus == TicketStatus.Assigned)
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@ticket.Id" />
                                            <input type="hidden" name="ticketStatus" value="@((int)TicketStatus.Repairing)" />
                                            <button type="submit" class="btn-primary-blue btn-sm">
                                                <i class="bi bi-tools me-1"></i>Repair
                                            </button>
                                        </form>
                                    }
                                    else if (ticket.TicketStatus == TicketStatus.Repairing)
                                    {
                                        <a asp-action="Complete" asp-route-id="@ticket.Id"
                                           class="btn-primary-blue btn-sm">
                                            <i class="bi bi-check-circle me-1"></i>Complete
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-ticket-detailed text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">No Tickets Found</h5>
                                    <p class="text-muted mb-0">Get started by creating a new ticket.</p>
                                    <a asp-action="Create" class="btn-primary-blue mt-3">
                                        <i class="bi bi-plus-circle-fill me-2"></i>New Ticket
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('ticketSearch')?.addEventListener('keyup', function () {
            const value = this.value.toLowerCase();
            document.querySelectorAll('#ticketTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? '' : 'none';
            });
        });
    </script>
}
