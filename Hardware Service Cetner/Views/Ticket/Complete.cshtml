@model TicketReportViewModel
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Complete Ticket";
}

<div class="page-content">

    @if (TempData["Error"] != null)
    {
        <div class="theme-alert alert-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span class="fw-medium">@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Report"><i class="bi bi-ticket-detailed me-1"></i>Tickets</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Complete</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-check-circle me-2 text-primary"></i>Complete Ticket</h2>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="theme-card h-100">
                <div class="theme-card-header">
                    <div class="header-icon">
                        <i class="bi bi-ticket-detailed-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Ticket Details</h5>
                        <small>@Model.TicketNo</small>
                    </div>
                </div>
                <div class="theme-card-body">
                    <div class="mb-3">
                        <label class="text-muted small fw-semibold text-uppercase">Customer</label>
                        <p class="fw-semibold fs-5 mb-0 mt-1"><i class="bi bi-person-fill text-primary me-2"></i>@Model.CustomerName</p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small fw-semibold text-uppercase">Device</label>
                        <p class="fw-semibold fs-5 mb-0 mt-1"><i class="bi bi-display text-primary me-2"></i>@Model.DeviceName</p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small fw-semibold text-uppercase">Technician</label>
                        <p class="fw-semibold mb-0 mt-1"><i class="bi bi-person-gear text-primary me-2"></i>@(Model.TechnicianName ?? "-")</p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small fw-semibold text-uppercase">Description</label>
                        <p class="mb-0 mt-1">@(Model.TicketDescription ?? "-")</p>
                    </div>
                    <div class="mb-0">
                        <label class="text-muted small fw-semibold text-uppercase">Received Date</label>
                        <p class="mb-0 mt-1"><i class="bi bi-calendar text-primary me-2"></i>@Model.RecDate.ToString("dd-MMM-yyyy")</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="theme-card">
                <div class="theme-card-header">
                    <div class="header-icon">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Service Charges</h5>
                        <small>Enter the service amount and remarks</small>
                    </div>
                </div>
                <div class="theme-card-body">
                    <form asp-action="Complete" method="post" novalidate>
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="row g-4">
                            <div class="col-12">
                                <div class="form-floating">
                                    <input name="Amount" class="form-control form-control-custom" placeholder="0.00" type="number" step="0.01" required />
                                    <label><i class="bi bi-currency-dollar me-2 text-primary"></i>Amount</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea name="Remarks" class="form-control form-control-custom" placeholder="Remarks" style="height: 120px"></textarea>
                                    <label><i class="bi bi-chat-dots me-2 text-primary"></i>Remarks</label>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Report" class="btn-secondary-outline px-4">
                                <i class="bi bi-arrow-left"></i>Back
                            </a>
                            <button type="submit" class="btn-primary-blue px-5">
                                <i class="bi bi-check-lg"></i>Complete & Save
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
