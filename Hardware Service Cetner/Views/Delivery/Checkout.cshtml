@model DeliveryModel
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Delivery Checkout";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-start border-danger border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <span class="fw-medium">@TempData["Error"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house-fill me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none"><i class="bi bi-truck me-1"></i>Pending Deliveries</a></li>
            <li class="breadcrumb-item active fw-semibold" aria-current="page">Checkout</li>
        </ol>
    </nav>
    <h3 class="fw-bold text-dark mb-0"><i class="bi bi-cart-check fs-3 me-2 text-primary"></i>Delivery Checkout</h3>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-primary text-white rounded-top-4 py-3 px-4">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 bg-white bg-opacity-25 p-2 me-3">
                        <i class="bi bi-box-seam-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-semibold">Complete Delivery</h5>
                        <span class="small opacity-75">Fill in the delivery details below</span>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Checkout" method="post" novalidate>
                    <input type="hidden" asp-for="TicketId" value="@Model.TicketId" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="UserId" class="form-control rounded-3" placeholder="User ID" />
                                <label asp-for="UserId"><i class="bi bi-person-badge-fill me-2 text-primary"></i>User ID</label>
                                <span asp-validation-for="UserId" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="RecDate" class="form-control rounded-3" type="date"
                                       value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <label asp-for="RecDate"><i class="bi bi-calendar-date me-2 text-primary"></i>Delivery Date</label>
                                <span asp-validation-for="RecDate" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Amount" class="form-control rounded-3" placeholder="0.00" type="number" step="0.01" />
                                <label asp-for="Amount"><i class="bi bi-currency-dollar me-2 text-primary"></i>Amount</label>
                                <span asp-validation-for="Amount" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="PaymentMethod" class="form-select rounded-3">
                                    <option value="">-- Select Payment --</option>
                                    <option value="Cash">Cash</option>
                                    <option value="Card">Card</option>
                                    <option value="UPI">UPI</option>
                                    <option value="Bank Transfer">Bank Transfer</option>
                                </select>
                                <label asp-for="PaymentMethod"><i class="bi bi-credit-card me-2 text-primary"></i>Payment Method</label>
                                <span asp-validation-for="PaymentMethod" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea asp-for="Remarks" class="form-control rounded-3" placeholder="Remarks" style="height: 100px"></textarea>
                                <label asp-for="Remarks"><i class="bi bi-chat-dots me-2 text-primary"></i>Remarks</label>
                                <span asp-validation-for="Remarks" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-3 px-4 py-2">
                            <i class="bi bi-arrow-left fs-5 me-1 align-middle"></i>Back
                        </a>
                        <button type="submit" class="btn btn-success rounded-3 px-5 py-2 shadow-sm">
                            <i class="bi bi-check-lg fs-5 me-1 align-middle"></i>Confirm Delivery
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
