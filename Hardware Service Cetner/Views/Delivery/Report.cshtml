@model IEnumerable<DeliveryReportViewModel>
@using Hardware_Service_Cetner.Enums

@{
    ViewData["Title"] = "Delivery Report";
    var total = Model.Count();
    var pending = Model.Count(d => d.Status == DeliveryStatus.pendint);
    var delivered = Model.Count(d => d.Status == DeliveryStatus.delivered);
}

<div class="page-content">
    @if (TempData["Success"] != null)
    {
        <div class="theme-alert alert-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span class="fw-medium">@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="theme-alert alert-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span class="fw-medium">@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="theme-header d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-custom mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill me-1"></i>Home</a></li>
                    <li class="breadcrumb-item active fw-semibold" aria-current="page">Delivery Report</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-box-seam me-2 text-primary"></i>Delivery Report</h2>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn-secondary-outline">
                <i class="bi bi-truck"></i>Pending Deliveries
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(13,110,253,0.12); color: #0d6efd;">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div>
                        <p class="stat-label">Total Deliveries</p>
                        <p class="stat-value">@total</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(255,193,7,0.12); color: #ffc107;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <p class="stat-label">Pending</p>
                        <p class="stat-value">@pending</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="theme-stat-card">
                <div class="stat-body">
                    <div class="stat-icon" style="background: rgba(25,135,84,0.12); color: #198754;">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div>
                        <p class="stat-label">Delivered</p>
                        <p class="stat-value">@delivered</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="theme-table-wrapper">
        <div class="table-toolbar">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" id="reportSearch" placeholder="Search deliveries..." />
            </div>
            <span class="text-muted small fw-medium">
                <i class="bi bi-layout-text-window me-1"></i>Showing <strong>@total</strong> delivery record(s)
            </span>
        </div>
        <div class="table-responsive">
            <table class="table-custom" id="deliveryReportTable">
                <thead>
                    <tr>
                        <th>S.N</th>
                        <th>Ticket No</th>
                        <th>Customer</th>
                        <th>Device</th>
                        <th>Amount</th>
                        <th>Payment</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Date</th>
                        <th class="text-center">Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var i = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-muted">@(i++)</td>
                                <td class="fw-semibold">
                                    <span class="d-inline-block bg-primary bg-opacity-10 text-primary rounded-2 px-3 py-1">
                                        <i class="bi bi-ticket me-1"></i>@item.TicketNo
                                    </span>
                                </td>
                                <td><i class="bi bi-person-fill text-muted me-1"></i>@item.CustomerName</td>
                                <td>@item.DeviceName</td>
                                <td class="fw-semibold">
                                    @if (item.Amount > 0)
                                    {
                                        <span class="text-dark"><i class="bi bi-currency-dollar text-muted me-1"></i>@item.Amount.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.PaymentMethod))
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2">
                                            <i class="bi bi-credit-card me-1"></i>@item.PaymentMethod
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Status == DeliveryStatus.delivered)
                                    {
                                        <span class="badge-custom badge-completed"><i class="bi bi-check-circle me-1"></i>Delivered</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-pending"><i class="bi bi-clock me-1"></i>Pending</span>
                                    }
                                </td>
                                <td class="text-center text-muted small">@item.RecDate.ToString("dd-MMM-yy")</td>
                                <td class="text-center text-muted small">@(item.Remarks ?? "-")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-box-seam text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3 fw-semibold">No Deliveries Yet</h5>
                                    <p class="text-muted mb-0">Complete tickets will appear here after delivery.</p>
                                    <a asp-action="Index" class="btn-secondary-outline mt-3">
                                        <i class="bi bi-truck me-2"></i>Process Deliveries
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('reportSearch')?.addEventListener('keyup', function () {
            const value = this.value.toLowerCase();
            document.querySelectorAll('#deliveryReportTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? '' : 'none';
            });
        });
    </script>
}
